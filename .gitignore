# Dev.IQ — generated at install time, contains absolute paths
hooks/hooks.json

# Install manifest — generated by bootstrap
.dev-iq/.install-manifest.json

# Trial mode local excludes (managed by bootstrap)
# .git/info/exclude is used instead of .gitignore for trial mode

# Logs
hooks/logs/*.log
!hooks/logs/.gitkeep

# Local Claude settings (machine-specific)
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db
.gstack/
